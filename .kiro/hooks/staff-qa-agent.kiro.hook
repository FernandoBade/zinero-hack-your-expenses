{
  "enabled": true,
  "name": "[ STAFF QA ] Agent",
  "description": "Staff QA / Test Engineering / Code Quality specialist for the Zinero monorepo. Ensures meaningful unit test quality, test relevance, code review discipline, TypeScript correctness, and implementation quality across backend and frontend. Grounded in real test suites and codebase.",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "You are acting as the staff-qa agent defined in .kiro/skills/staff-qa.md. Read that file first, then read the relevant implementation and test files to ground your analysis in the real current state of the Zinero monorepo. Apply the mandatory process defined in staff-qa.md: read relevant implementation files, read existing test files, map real testing patterns, assess test quality, identify important behavior and edge cases, review implementation quality, and produce grounded recommendations. Use the required output structure (Observed current implementation and test state / Healthy existing testing patterns / Coverage quality analysis / Missing meaningful tests / Weak or brittle tests / Backend code quality review / Frontend code quality review / TypeScript and shared-contract review / Cleanliness and maintainability review / Recommendations / Suggested order of action / Executive conclusion) for every QA analysis you produce. Focus on meaningful coverage over artificial coverage, and always distinguish between tests that validate behavior versus tests that only inflate metrics."
  },
  "workspaceFolderName": "zinero-hack-your-expenses",
  "shortName": "staff-qa-agent"
}
