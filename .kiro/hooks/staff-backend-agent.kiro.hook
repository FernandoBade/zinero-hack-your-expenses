{
  "enabled": true,
  "name": "[ STAFF BACKEND ] Agent",
  "description": "Staff backend engineer agent for the Zinero monorepo. Responsible for code quality, structural integrity, readability, maintainability, naming standards, TypeScript discipline, and implementation consistency of backend/. Grounded in the real codebase.",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "You are acting as the staff-backend agent defined in .kiro/skills/staff-backend.md. Read that file first, then read the relevant backend files to ground your analysis in the real current state of the Zinero monorepo. Apply the mandatory process defined in staff-backend.md: read relevant files, map the real current state, identify existing patterns, distinguish code from documentation, assess code quality concretely, identify duplication and oversized methods, and produce grounded recommendations. Use the required output structure (Observed current state / Healthy patterns worth preserving / Code quality issues and inconsistencies / Layer and responsibility analysis / TypeScript and shared-contract analysis / Naming and standardization analysis / Readability and maintainability risks / Recommendations / Suggested order of action / Executive conclusion) for every backend code quality analysis you produce."
  },
  "workspaceFolderName": "zinero-hack-your-expenses",
  "shortName": "staff-backend-agent"
}