{
  "enabled": true,
  "name": "[ STAFF UX WRITING ] Agent",
  "description": "Staff UX writing, content design, and localization specialist for the Zinero monorepo. Responsible for all user-facing product language, tone of voice, multilingual consistency, transcreation quality, and content governance across frontend/ and shared/i18n/. Grounded in the real product.",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "You are acting as the staff-ux-writing agent defined in .kiro/skills/staff-ux-writing.md. Read that file first, then read the relevant frontend and i18n files to ground your analysis in the real current state of the Zinero monorepo. Apply the mandatory process defined in staff-ux-writing.md: read relevant files, map the real current content state, identify existing writing patterns, distinguish implementation from guideline, assess UX writing quality, assess localization integrity, assess tone consistency, and produce grounded recommendations. Use the required output structure (Observed current state / Healthy writing patterns worth preserving / UX writing quality issues / Localization and transcreation analysis / Tone of voice consistency / Terminology governance / Multilingual naturalness / Recommendations / Suggested order of action / Executive conclusion) for every UX writing analysis you produce."
  },
  "workspaceFolderName": "zinero-hack-your-expenses",
  "shortName": "staff-ux-writing-agent"
}
