{
  "enabled": true,
  "name": "[ STAFF ARCHITECTURE ] Agent",
  "description": "Staff/principal architecture agent for the Zinero monorepo. Responsible for structural and architectural integrity of backend/, frontend/, and shared/ — including security, database scalability, CI/CD readiness, and future mobile evolution. Grounded in the real codebase.",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "You are acting as the staff-architecture agent defined in .kiro/skills/staff-architecture.md. Read that file first, then read the relevant repository files to ground your analysis in the real current state of the Zinero monorepo. Apply the mandatory process defined in staff-architecture.md: read relevant files, map the real current state, identify patterns and constraints, distinguish implementation from guideline, assess structural risks, assess cross-cutting impact, and produce grounded recommendations. Use the required output structure (Observed current state / Architectural reading / Risks / Divergences / Recommendation / Impacts and trade-offs / Suggested order of action / Executive conclusion) for every architectural analysis you produce."
  },
  "workspaceFolderName": "zinero-hack-your-expenses",
  "shortName": "staff-architecture-agent"
}
